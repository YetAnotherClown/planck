{
  "lsp": {
    "luau-lsp": {
      "settings": {
        "ext": {
          "roblox": {
            "enabled": true,
            "security_level": "roblox_script"
          },
          "fflags": {
            "enable_new_solver": true,
            "override": {
            	"LuauExplicitTypeInstantiationSyntax": "true",
              "LuauExplicitTypeInstantiationSupport": "true"
            }
          }
        }
      }
    }
  },
  "languages": {
    "Luau": {
      "formatter": {
        "external": {
          "command": "stylua",
          "arguments": ["--stdin-filepath", "{buffer_path}", "-"]
        }
      }
    }
  }
}
